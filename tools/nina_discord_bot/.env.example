# NINA Discord Bot Configuration
# ================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env with your real token to git!

# Discord Bot Token (required)
# Get yours at: https://discord.com/developers/applications
# 1. Create a New Application
# 2. Go to Bot → Reset Token → Copy
# 3. Enable MESSAGE CONTENT INTENT in Bot settings
# 4. Invite bot with: OAuth2 → URL Generator → bot scope → Send Messages + Read Messages
NINA_DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# LLM Server URL (llama-server endpoint)
# Default: http://127.0.0.1:8080
NINA_LLM_URL=http://127.0.0.1:8080

# Optional: Restrict bot to a specific Discord channel ID
# Leave empty to respond in all channels when mentioned
# Right-click a channel → Copy Channel ID (enable Developer Mode in Discord settings)
NINA_CHANNEL_ID=

# NinaCatCoin Daemon RPC URL (for real-time network stats)
# Point to your running ninacatcoind RPC endpoint
# Default mainnet RPC port: 19021
NINA_DAEMON_RPC=http://127.0.0.1:19021
